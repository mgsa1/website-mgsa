---
import { projects } from '../data/projects';
---

<section id="projects" class="relative px-6 pt-8 pb-16 md:pt-10 md:pb-24">
  <!-- PCB texture background -->
  <div
    class="pointer-events-none absolute inset-0"
    style="background-image: url('/pcb-texture.svg'); background-repeat: repeat; background-size: 100px 100px; opacity: 0.04;"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-[42rem]">
    <h2 class="mb-10 text-xl font-semibold text-text" style="letter-spacing: -0.01em;">
      Projects
    </h2>

    <div class="flex flex-col gap-4">
      {
        projects.map((project) => (
          project.url ? (
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="block focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent rounded-sm">
              <article class="group flex flex-col gap-3 rounded-sm border border-border bg-bg p-5 transition-colors hover:border-muted">
                <div class="flex items-start justify-between gap-2">
                  <h3 class="text-base font-semibold leading-snug text-text group-hover:text-accent transition-colors">
                    {project.title}
                    <span class="inline-block ml-1 text-muted group-hover:text-accent transition-colors" aria-hidden="true">↗</span>
                  </h3>
                  <span class="shrink-0 font-mono text-xs text-muted">{project.year}</span>
                </div>

                <p class="text-base leading-relaxed text-muted">{project.description}</p>

                <div class="mt-auto flex flex-wrap gap-1.5">
                  {project.tags.map((tag) => (
                    <span class="rounded-sm border border-border px-2 py-0.5 font-mono text-xs text-muted">
                      {tag}
                    </span>
                  ))}
                </div>
              </article>
            </a>
          ) : (
            <article class="group flex flex-col gap-3 rounded-sm border border-border bg-bg p-5 transition-colors hover:border-muted">
              <div class="flex items-start justify-between gap-2">
                <h3 class="text-base font-semibold leading-snug text-text">
                  {project.title}
                </h3>
                <span class="shrink-0 font-mono text-xs text-muted">{project.year}</span>
              </div>

              <p class="text-base leading-relaxed text-muted">{project.description}</p>

              <div class="mt-auto flex flex-wrap gap-1.5">
                {project.tags.map((tag) => (
                  <span class="rounded-sm border border-border px-2 py-0.5 font-mono text-xs text-muted">
                    {tag}
                  </span>
                ))}
              </div>
            </article>
          )
        ))
      }
    </div>
  </div>
</section>
