---
---

<section class="px-6 pt-16 pb-8 md:pt-20 md:pb-10">
  <div class="mx-auto max-w-[42rem]">
    <!-- Terminal line -->
    <p
      id="terminal-line"
      class="mb-10 min-h-[1.4em] font-mono text-sm text-muted"
      aria-label="mgsa --location San Francisco --from Paris · Zürich"
    ></p>

    <!-- Main hero content, hidden until animation completes (JS shows it; noscript fallback below) -->
    <div id="hero-main" style="opacity: 0; transition: opacity 0.8s ease;">
    <noscript><style>#hero-main { opacity: 1 !important; }</style></noscript>
      <h1 class="mb-4 text-4xl font-semibold tracking-tight text-text md:text-5xl">
        mgsa
      </h1>
      <p class="text-base text-muted md:text-lg">
        Robotics <span class="text-accent">·</span> Hardware <span class="text-accent">·</span> AI
      </p>
    </div>
  </div>
</section>

<script>
  const terminalEl = document.getElementById('terminal-line')!;
  const heroMain = document.getElementById('hero-main')!;
  const text = '> mgsa --location "San Francisco" --from "Paris · Zürich"';
  let i = 0;

  function type() {
    if (i < text.length) {
      terminalEl.textContent += text[i++];
      setTimeout(type, 32);
    } else {
      // Blinking cursor after typing completes
      const cursor = document.createElement('span');
      cursor.className = 'terminal-cursor';
      cursor.textContent = '▋';
      terminalEl.appendChild(cursor);

      // Fade in the name + tagline (shortened from 350ms)
      setTimeout(() => {
        heroMain.style.opacity = '1';
      }, 150);
    }
  }

  // Respect prefers-reduced-motion: skip animation and show everything immediately
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    terminalEl.textContent = text;
    const cursor = document.createElement('span');
    cursor.className = 'terminal-cursor';
    cursor.textContent = '▋';
    terminalEl.appendChild(cursor);
    heroMain.style.opacity = '1';
  } else {
    // Small delay before starting (shortened from 400ms)
    setTimeout(type, 200);
  }
</script>

<style>
  .terminal-cursor {
    color: var(--color-accent);
    animation: blink 1.1s step-end infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
</style>
